{
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "cSpell.words": [
    "antonswebfabrik",
    "Aptoide",
    "fernwaerts",
    "Fernwärts",
    "fpdart",
    "github",
    "Insertable",
    "junitreport",
    "latlong",
    "linux",
    "maplibre",
    "monday",
    "powersync",
    "pubspec",
    "reauthentication",
    "SHORTWEEKDAYS",
    "sqflite",
    "sqlite",
    "subosito",
    "supabase",
    "Supabase",
    "tojunit",
    "tracelet",
    "usecases",
    "uuid",
    "Webfabrik"
  ],
  "deno.enablePaths": [
    "supabase/functions"
  ],
  "deno.lint": true,
  "deno.unstable": [
    "bare-node-builtins",
    "byonm",
    "sloppy-imports",
    "unsafe-proto",
    "webgpu",
    "broadcast-channel",
    "worker-options",
    "cron",
    "kv",
    "ffi",
    "fs",
    "http",
    "net"
  ],
  "deno.enable": true,
  "[sql]": {
    "editor.defaultFormatter": "inferrinizzard.prettier-sql-vscode"
  },
  "Prettier-SQL.keywordCase": "lower",
  "continue.pauseCodebaseIndexOnStart": true,
  "continue.pauseTabAutocompleteOnBattery": true,
  "continue.telemetryEnabled": false
}